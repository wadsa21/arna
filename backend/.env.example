# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
DJANGO_SETTINGS_MODULE=arna_project.settings.development
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# PostgreSQL
DB_NAME=arna
DB_USER=arna
DB_PASSWORD=arna
DB_HOST=localhost
DB_PORT=5432

# Redis (Celery broker + Channels layer)
REDIS_URL=redis://localhost:6379/0

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_SCHEDULE_COMPLETED=arna.schedule.completed
KAFKA_TOPIC_BEHAVIOR_LOGGED=arna.behavior.logged
KAFKA_TOPIC_AI_ANALYZE=arna.ai.analyze
KAFKA_CONSUMER_GROUP=arna-backend

# JWT
JWT_ACCESS_LIFETIME_MIN=60
JWT_REFRESH_LIFETIME_DAYS=7
